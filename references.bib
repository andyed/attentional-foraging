  title     = {{RocketQA}: An Optimized Training Approach to Dense Passage Retrieval for Open-Domain Question Answering},
  booktitle = {Proceedings of the 2021 Conference of the North American Chapter of the Association for Computational Linguistics: Human Language Technologies},
  series    = {NAACL-HLT '21},
  pages     = {5835--5847},
  year      = {2021},
  publisher = {Association for Computational Linguistics},
  doi       = {10.18653/v1/2021.naacl-main.466},
  url       = {\url{https://arxiv.org/abs/2010.08191}},
  note      = {RocketQA. Three technical contributions: cross-batch negatives, denoised hard negatives, and data augmentation. Most important for the approach-retreat framing: false negatives in mined hard-negative pools are a real failure mode, addressed by filtering the pool with a stronger cross-encoder that scores "plausibly relevant" candidates out of the training set. Establishes that denoising is load-bearing for hard-negative mining, not optional. Approach-retreat's evaluated-rejected class addresses this by construction — the user's retreat is behavioral evidence of active rejection rather than a model-inferred guess at irrelevance. DOI from LLM knowledge, re-verify.},
}


