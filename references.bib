@inproceedings{xiong2021ance,
  author    = {Xiong, Lee and Xiong, Chenyan and Li, Ye and Tang, Kwok-Fung and Liu, Jialin and Bennett, Paul N. and Ahmed, Junaid and Overwijk, Arnold},
  title     = {Approximate Nearest Neighbor Negative Contrastive Learning for Dense Text Retrieval},
  booktitle = {Proceedings of the 9th International Conference on Learning Representations},
  series    = {ICLR '21},
  year      = {2021},
  url       = {\url{https://openreview.net/forum?id=zeFrfgyZln}},
  note      = {ANCE. Theoretical argument that "the bottleneck of dense retrieval is the domination of uninformative negatives sampled in mini-batch training, which yield diminishing gradient norms, large gradient variances, and slow convergence." Fix: globally re-mine hard negatives from the entire corpus every ~10k training steps using the current model's index, approximating oracle importance sampling. The "hard negatives matter" headline for modern dense retrieval. Also on arXiv at 2007.00808.},
}

@inproceedings{zhan2021hardnegatives,
  author    = {Zhan, Jingtao and Mao, Jiaxin and Liu, Yiqun and Guo, Jiafeng and Zhang, Min and Ma, Shaoping},
