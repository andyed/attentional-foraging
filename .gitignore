# Data (downloaded from Zenodo, not ours)
AdSERP/data/fixation-data/
AdSERP/data/mouse-movement-data/
AdSERP/data/trial-metadata/
AdSERP/data/*.zip
AdSERP/data/serps/

# Python
.venv/
__pycache__/

# Output (reproducible from notebook)
convergence_results.json
phase_results.json

# Keep plot PNGs for README embedding
# plots are reproducible but needed for GitHub rendering
.DS_Store
site/
AdSERP/
docs/drafts/
docs/plans/

# Agent workspace dirs
.claude/
.claire/

# claude-mem scaffolding — regenerated per subdir, breaks SSG globs.
# Keep the real root CLAUDE.md only.
**/CLAUDE.md
!/CLAUDE.md

# LaTeX build artifacts
docs/arxiv/*.aux
docs/arxiv/*.bbl
docs/arxiv/*.blg
docs/arxiv/*.log
docs/arxiv/*.out

# Audit/diagnostic scripts (local utility, not production)
notebooks-v2/_*.py

# Pre-fix backup JSONs (local reproducibility)
*.prefix-bug.json
*.html
# Replay app source HTML is kept in git; generated data dir is not
!docs/schul-replay/*.html
docs/schul-replay/data/

# Per-record figure caches — large (10-15 MB), reproducible from source scripts
scripts/output/figures/per_record_*.json
